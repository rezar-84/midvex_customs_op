<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Customs Office List View -->
    <record id="view_customs_office_tree" model="ir.ui.view">
        <field name="name">customs.office.list</field>
        <field name="model">customs.office</field>
        <field name="arch" type="xml">
            <list string="Customs Offices">
                <field name="code"/>
                <field name="name"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- Customs Office Form View -->
    <record id="view_customs_office_form" model="ir.ui.view">
        <field name="name">customs.office.form</field>
        <field name="model">customs.office</field>
        <field name="arch" type="xml">
            <form string="Customs Office">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="bg-danger" invisible="active"/>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                        </group>
                        <group>
                            <field name="company_id" groups="base.group_multi_company" options="{'no_create': True}"/>
                            <field name="active"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Customs Office Search View -->
    <record id="view_customs_office_search" model="ir.ui.view">
        <field name="name">customs.office.search</field>
        <field name="model">customs.office</field>
        <field name="arch" type="xml">
            <search string="Search Customs Offices">
                <field name="name"/>
                <field name="code"/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>
</odoo>
