<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Stage List View -->
    <record id="view_customs_stage_tree" model="ir.ui.view">
        <field name="name">customs.stage.list</field>
        <field name="model">customs.stage</field>
        <field name="arch" type="xml">
            <list string="Stages">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="fold"/>
                <field name="is_closed"/>
                <field name="is_cancelled"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <!-- Stage Form View -->
    <record id="view_customs_stage_form" model="ir.ui.view">
        <field name="name">customs.stage.form</field>
        <field name="model">customs.stage</field>
        <field name="arch" type="xml">
            <form string="Stage">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="sequence"/>
                            <field name="company_id" groups="base.group_multi_company" options="{'no_create': True}"/>
                        </group>
                        <group>
                            <field name="fold"/>
                            <field name="is_closed"/>
                            <field name="is_cancelled"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Stage Search View -->
    <record id="view_customs_stage_search" model="ir.ui.view">
        <field name="name">customs.stage.search</field>
        <field name="model">customs.stage</field>
        <field name="arch" type="xml">
            <search string="Search Stages">
                <field name="name"/>
                <field name="code"/>
            </search>
        </field>
    </record>
</odoo>
