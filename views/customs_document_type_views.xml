<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Document Type List View -->
    <record id="view_customs_document_type_tree" model="ir.ui.view">
        <field name="name">customs.document.type.list</field>
        <field name="model">customs.document.type</field>
        <field name="arch" type="xml">
            <list string="Document Types">
                <field name="sequence" widget="handle"/>
                <field name="code"/>
                <field name="name"/>
                <field name="name_tr"/>
                <field name="default_responsible_party"/>
                <field name="default_requirement_level"/>
                <field name="original_normally_required"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- Document Type Form View -->
    <record id="view_customs_document_type_form" model="ir.ui.view">
        <field name="name">customs.document.type.form</field>
        <field name="model">customs.document.type</field>
        <field name="arch" type="xml">
            <form string="Document Type">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="bg-danger" invisible="active"/>
                    <div class="oe_title">
                        <span class="o_form_label">Document Code</span>
                        <h1>
                            <field name="code" placeholder="e.g. COA, HC, COO" required="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="name" placeholder="English Name"/>
                            <field name="name_tr" placeholder="Turkish Name"/>
                            <field name="sequence"/>
                            <field name="active" invisible="1"/>
                        </group>
                        <group>
                            <field name="default_responsible_party"/>
                            <field name="default_requirement_level"/>
                            <field name="original_normally_required"/>
                            <field name="company_id" groups="base.group_multi_company" options="{'no_create': True}"/>
                        </group>
                    </group>
                    <group string="Description">
                        <field name="description" placeholder="Describe the document purpose, standard guidelines, etc..."/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Document Type Search View -->
    <record id="view_customs_document_type_search" model="ir.ui.view">
        <field name="name">customs.document.type.search</field>
        <field name="model">customs.document.type</field>
        <field name="arch" type="xml">
            <search string="Search Document Types">
                <field name="name"/>
                <field name="code"/>
                <field name="name_tr"/>
                <filter string="Mandatory by Default" name="mandatory" domain="[('default_requirement_level', '=', 'mandatory')]"/>
                <filter string="Optional by Default" name="optional" domain="[('default_requirement_level', '=', 'optional')]"/>
                <filter string="Original Required" name="original_required" domain="[('original_normally_required', '=', True)]"/>
                <separator/>
                <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Responsible Party" name="group_responsible" context="{'group_by': 'default_responsible_party'}"/>
                    <filter string="Requirement Level" name="group_level" context="{'group_by': 'default_requirement_level'}"/>
                    <filter string="Company" name="group_company" context="{'group_by': 'company_id'}" groups="base.group_multi_company"/>
                </group>
            </search>
        </field>
    </record>
</odoo>
