<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_customs_inherit" model="ir.ui.view">
        <field name="name">account.move.form.customs.inherit</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <!-- Add smart button to button box -->
            <div name="button_box" position="inside">
                <button name="action_view_customs_operations" 
                        type="object" 
                        class="oe_stat_button" 
                        icon="fa-folder-open-o" 
                        invisible="not customs_operation_id or move_type != 'in_invoice'">
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_text">Customs File</span>
                    </div>
                </button>
            </div>

            <!-- Add Many2one field to the form -->
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="customs_operation_id" 
                       invisible="move_type != 'in_invoice'" 
                       options="{'no_create': True}"/>
            </xpath>
        </field>
    </record>
</odoo>
