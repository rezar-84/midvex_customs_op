<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="portal_my_home_menu_customs" name="Portal layout: customs menu entries" inherit_id="portal.portal_breadcrumbs" priority="35">
        <xpath expr="//ol[hasclass('o_portal_submenu')]" position="inside">
            <li t-if="page_name in ('customs_operations', 'customs_operation')" t-attf-class="breadcrumb-item #{'active ' if page_name == 'customs_operations' else ''}">
                <a t-if="page_name == 'customs_operation'" t-attf-href="/my/customs?{{ keep_query() }}">Customs Operations</a>
                <t t-else="">Customs Operations</t>
            </li>
            <li t-if="page_name == 'customs_operation'" class="breadcrumb-item active">
                <t t-out="operation.name"/>
            </li>
        </xpath>
    </template>

    <template id="portal_my_home_customs" name="Customs Operations" inherit_id="portal.portal_my_home" priority="35">
        <xpath expr="//div[hasclass('o_portal_docs')]" position="before">
            <t t-set="portal_vendor_category_enable" t-value="True"/>
        </xpath>
        <div id="portal_vendor_category" position="inside">
            <t t-call="portal.portal_docs_entry">
                <t t-set="icon" t-value="'/web/static/img/folder.svg'"/>
                <t t-set="title">Customs Operations</t>
                <t t-set="text">Track import documents and customs status</t>
                <t t-set="url" t-value="'/my/customs'"/>
                <t t-set="placeholder_count" t-value="'customs_operation_count'"/>
            </t>
        </div>
    </template>

    <template id="portal_my_customs_operations" name="My Customs Operations">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>
            <t t-call="portal.portal_searchbar">
                <t t-set="title">Customs Operations</t>
            </t>
            <t t-if="not operations">
                <p class="alert alert-warning shadow-sm">There are currently no Customs Operations linked to your account.</p>
            </t>
            <t t-if="operations" t-call="portal.portal_table">
                <thead>
                    <tr class="active">
                        <th>Reference</th>
                        <th>Supplier</th>
                        <th class="d-none d-md-table-cell">B/L Number</th>
                        <th class="d-none d-md-table-cell">Stage</th>
                        <th class="d-none d-lg-table-cell">ETA</th>
                        <th class="text-center">Documents Progress</th>
                    </tr>
                </thead>
                <t t-foreach="operations" t-as="operation">
                    <tr class="align-middle">
                        <td>
                            <a class="fw-bold d-flex align-items-center gap-2" t-att-href="'/my/customs/%s' % operation.id">
                                <i class="fa fa-folder-open text-primary"/>
                                <t t-out="operation.name"/>
                            </a>
                        </td>
                        <td>
                            <t t-out="', '.join(operation.supplier_ids.mapped('display_name'))"/>
                        </td>
                        <td class="d-none d-md-table-cell">
                            <span t-if="operation.bl_number" class="font-monospace text-muted" t-out="operation.bl_number"/>
                            <span t-else="" class="text-muted small">Not set</span>
                        </td>
                        <td class="d-none d-md-table-cell">
                            <span class="badge bg-primary text-white" t-field="operation.stage_id"/>
                            <span t-if="operation.customs_status" class="badge bg-info text-dark ms-1" t-field="operation.customs_status"/>
                        </td>
                        <td class="d-none d-lg-table-cell">
                            <span t-if="operation.planned_arrival_date" t-field="operation.planned_arrival_date"/>
                            <span t-else="" class="text-muted small">Not set</span>
                        </td>
                        <td class="text-center" style="min-width: 150px;">
                            <div class="d-flex align-items-center justify-content-center gap-2">
                                <t t-set="total_docs" t-value="operation.document_total or 0"/>
                                <t t-set="approved_docs" t-value="operation.document_approved_count or 0"/>
                                <t t-set="progress_percent" t-value="int((approved_docs / total_docs * 100) if total_docs &gt; 0 else 0)"/>
                                
                                <div class="progress w-100 d-none d-sm-flex" style="height: 8px;">
                                    <div t-attf-class="progress-bar #{'bg-success' if progress_percent == 100 else 'bg-warning' if progress_percent &gt; 0 else 'bg-danger'}" role="progressbar" t-attf-style="width: #{progress_percent}%;" t-att-aria-valuenow="progress_percent" aria-valuemin="0" aria-valuemax="100"/>
                                </div>
                                <span t-attf-class="badge rounded-pill #{'bg-success' if progress_percent == 100 else 'bg-warning text-dark' if progress_percent &gt; 0 else 'bg-danger'}" style="min-width: 50px;">
                                    <t t-out="approved_docs"/>/<t t-out="total_docs"/>
                                </span>
                            </div>
                        </td>
                    </tr>
                </t>
            </t>
        </t>
    </template>

    <template id="portal_customs_operation" name="Customs Operation">
        <t t-call="portal.portal_layout">
            <!-- Header Block -->
            <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4 p-3 bg-white rounded shadow-sm border">
                <div>
                    <h3 class="mb-1 text-primary fw-bold" t-out="operation.name"/>
                    <div class="d-flex gap-2 align-items-center">
                        <span class="badge bg-primary fs-6" t-field="operation.stage_id"/>
                        <span t-if="operation.customs_status" class="badge bg-info fs-6" t-field="operation.customs_status"/>
                    </div>
                </div>
                <div class="d-flex gap-2">
                    <a t-if="is_broker" class="btn btn-primary" t-att-href="'/my/customs/%s/documents.zip' % operation.id">
                        <i class="fa fa-download me-1"/> Download Approved Documents ZIP
                    </a>
                </div>
            </div>

            <!-- Visual Shipment Timeline -->
            <div class="card mb-4 border shadow-sm">
                <div class="card-body">
                    <h6 class="card-title text-muted fw-bold mb-3">Shipment Progress</h6>
                    <div class="row text-center">
                        <t t-set="active_stage_seq" t-value="operation.stage_id.sequence or 0"/>
                        <div class="col">
                            <div t-attf-class="fw-bold #{'text-primary' if active_stage_seq &gt;= 1 else 'text-muted'}">Production</div>
                            <div class="mt-2">
                                <span t-attf-class="badge rounded-circle p-2 #{'bg-primary' if active_stage_seq &gt;= 1 else 'bg-secondary'}" style="width: 12px; height: 12px; display: inline-block;"/>
                            </div>
                        </div>
                        <div class="col">
                            <div t-attf-class="fw-bold #{'text-primary' if active_stage_seq &gt;= 14 else 'text-muted'}">Waiting for Docs</div>
                            <div class="mt-2">
                                <span t-attf-class="badge rounded-circle p-2 #{'bg-primary' if active_stage_seq &gt;= 14 else 'bg-secondary'}" style="width: 12px; height: 12px; display: inline-block;"/>
                            </div>
                        </div>
                        <div class="col">
                            <div t-attf-class="fw-bold #{'text-primary' if active_stage_seq &gt;= 50 else 'text-muted'}">In Transit</div>
                            <div class="mt-2">
                                <span t-attf-class="badge rounded-circle p-2 #{'bg-primary' if active_stage_seq &gt;= 50 else 'bg-secondary'}" style="width: 12px; height: 12px; display: inline-block;"/>
                            </div>
                        </div>
                        <div class="col">
                            <div t-attf-class="fw-bold #{'text-primary' if active_stage_seq &gt;= 68 else 'text-muted'}">Customs Clearance</div>
                            <div class="mt-2">
                                <span t-attf-class="badge rounded-circle p-2 #{'bg-primary' if active_stage_seq &gt;= 68 else 'bg-secondary'}" style="width: 12px; height: 12px; display: inline-block;"/>
                            </div>
                        </div>
                        <div class="col">
                            <div t-attf-class="fw-bold #{'text-primary' if active_stage_seq &gt;= 95 else 'text-muted'}">Delivered</div>
                            <div class="mt-2">
                                <span t-attf-class="badge rounded-circle p-2 #{'bg-primary' if active_stage_seq &gt;= 95 else 'bg-secondary'}" style="width: 12px; height: 12px; display: inline-block;"/>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Feedback Alerts -->
            <div t-if="success" class="alert alert-success alert-dismissible fade show" role="alert">
                <strong>Success!</strong> Your update has been successfully submitted and logged.
            </div>
            <div t-if="error == 'missing_file'" class="alert alert-danger alert-dismissible fade show" role="alert">
                <strong>Error!</strong> Please select a valid file before attempting to upload.
            </div>

            <!-- Shipment Details Card -->
            <div class="card mb-4 border shadow-sm">
                <div class="card-body">
                    <h6 class="card-title text-muted fw-bold mb-3">Shipment Overview</h6>
                    <div class="row g-3">
                        <div class="col-sm-6 col-md-4">
                            <small class="text-muted d-block">Supplier(s)</small>
                            <span class="fw-bold" t-out="', '.join(operation.supplier_ids.mapped('display_name'))"/>
                        </div>
                        <div class="col-sm-6 col-md-4">
                            <small class="text-muted d-block">Customs Broker</small>
                            <span class="fw-bold" t-field="operation.broker_id"/>
                        </div>
                        <div class="col-sm-6 col-md-4">
                            <small class="text-muted d-block">Estimated Arrival (ETA)</small>
                            <span class="fw-bold" t-if="operation.planned_arrival_date" t-field="operation.planned_arrival_date"/>
                            <span class="fw-bold text-muted" t-else="">Not set</span>
                        </div>
                        <div class="col-sm-6 col-md-4">
                            <small class="text-muted d-block">Bill of Lading (B/L)</small>
                            <span class="fw-bold" t-field="operation.bl_number"/>
                        </div>
                        <div class="col-sm-6 col-md-4">
                            <small class="text-muted d-block">Declaration Number</small>
                            <span class="fw-bold" t-field="operation.customs_declaration_number"/>
                        </div>
                        <div class="col-sm-6 col-md-4">
                            <small class="text-muted d-block">Declaration Date</small>
                            <span class="fw-bold" t-if="operation.customs_declaration_date" t-field="operation.customs_declaration_date"/>
                            <span class="fw-bold text-muted" t-else="">Not set</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Broker Form Section -->
            <div t-if="is_broker" class="card mb-4 border border-primary shadow-sm bg-light-subtle">
                <div class="card-body">
                    <h5 class="fw-bold text-primary mb-3">
                        <i class="fa fa-edit me-1"/> Customs Declaration Updates (Broker Only)
                    </h5>
                    <form t-att-action="'/my/customs/%s/broker/update' % operation.id" method="post" enctype="multipart/form-data">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                        <div class="row g-3">
                            <div class="col-sm-6 col-md-4">
                                <label class="form-label fw-semibold" for="customs_declaration_number">Declaration Number</label>
                                <input id="customs_declaration_number" name="customs_declaration_number" class="form-control" t-att-value="operation.customs_declaration_number or ''" placeholder="16-character format"/>
                            </div>
                            <div class="col-sm-6 col-md-4">
                                <label class="form-label fw-semibold" for="customs_declaration_date">Declaration Date</label>
                                <input id="customs_declaration_date" name="customs_declaration_date" type="date" class="form-control" t-att-value="operation.customs_declaration_date or ''"/>
                            </div>
                            <div class="col-sm-6 col-md-4">
                                <label class="form-label fw-semibold" for="customs_status">Customs Status</label>
                                <select id="customs_status" name="customs_status" class="form-select">
                                    <option value="">No change</option>
                                    <t t-foreach="operation._fields['customs_status'].selection" t-as="status_option">
                                        <option t-att-value="status_option[0]" t-att-selected="operation.customs_status == status_option[0]">
                                            <t t-out="status_option[1]"/>
                                        </option>
                                    </t>
                                </select>
                            </div>
                            <div class="col-md-8">
                                <label class="form-label fw-semibold" for="declaration_file">Declaration PDF (Upload signed copy)</label>
                                <input id="declaration_file" name="declaration_file" type="file" class="form-control"/>
                            </div>
                            <div class="col-md-4 d-flex align-items-end">
                                <button type="submit" class="btn btn-primary w-100 fw-bold">Submit Update</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Documents Section (Better Document Management Layout) -->
            <div class="card mb-4 border shadow-sm">
                <div class="card-body">
                    <h5 class="card-title fw-bold mb-4">Required Documents Checklist</h5>
                    
                    <t t-if="not operation.document_requirement_ids">
                        <p class="alert alert-info mb-0">No documents are currently requested for this shipment.</p>
                    </t>
                    
                    <t t-else="">
                        <div class="row g-3">
                            <t t-foreach="operation.document_requirement_ids" t-as="requirement">
                                <t t-set="is_action_needed" t-value="requirement.state in ('rejected', 'correction_required')"/>
                                <t t-set="is_approved" t-value="requirement.state in ('approved', 'accepted', 'original_received', 'submitted_to_customs')"/>
                                <t t-set="is_pending" t-value="not is_approved and not is_action_needed"/>
                                
                                <div class="col-md-6 col-lg-4">
                                    <div t-attf-class="card h-100 border #{'border-danger bg-danger-subtle text-danger-emphasis' if is_action_needed else 'border-success bg-success-subtle text-success-emphasis' if is_approved else 'border-info-subtle bg-info-subtle text-info-emphasis'}">
                                        <div class="card-body d-flex flex-column justify-content-between">
                                            <div>
                                                <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                                                    <h6 class="fw-bold mb-0 text-dark" t-out="requirement.name"/>
                                                    <span t-attf-class="badge #{'bg-danger' if is_action_needed else 'bg-success' if is_approved else 'bg-info text-dark'}" t-field="requirement.state"/>
                                                </div>
                                                
                                                <div class="small text-muted mb-2">
                                                    <strong>Responsible:</strong> <span t-field="requirement.responsible_party"/>
                                                    <span t-if="requirement.deadline" class="d-block">
                                                        <strong>Deadline:</strong> <span t-field="requirement.deadline"/>
                                                    </span>
                                                </div>

                                                <!-- Rejection Message callout -->
                                                <div t-if="is_action_needed and requirement.rejection_reason" class="alert alert-danger py-1 px-2 mb-2 small">
                                                    <i class="fa fa-exclamation-triangle me-1"/> <t t-out="requirement.rejection_reason"/>
                                                </div>
                                            </div>

                                            <div>
                                                <!-- Version and uploads details -->
                                                <div t-if="requirement.attachment_ids" class="mb-3">
                                                    <div class="text-muted small mb-1">
                                                        <strong>Version:</strong> v<span t-field="requirement.version_number"/> | <t t-out="len(requirement.attachment_ids)"/> Files
                                                    </div>
                                                    <div class="list-group list-group-flush border rounded overflow-hidden">
                                                        <t t-foreach="requirement.attachment_ids" t-as="attach">
                                                            <a t-attf-href="/web/content/#{attach.id}?download=true" class="list-group-item list-group-item-action py-1 px-2 small text-truncate text-primary" t-att-title="attach.name">
                                                                <i class="fa fa-file me-1"/> <t t-out="attach.name"/>
                                                            </a>
                                                        </t>
                                                    </div>
                                                </div>

                                                <!-- Supplier Upload Form -->
                                                <form t-if="is_supplier and requirement.responsible_party in ('supplier', 'manufacturer')" t-att-action="'/my/customs/document/%s/upload' % requirement.id" method="post" enctype="multipart/form-data" class="mt-2">
                                                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                                    <div class="input-group input-group-sm">
                                                        <input name="document_file" type="file" class="form-control" required="required"/>
                                                        <button type="submit" class="btn btn-primary fw-bold">Upload</button>
                                                    </div>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </t>
                        </div>
                    </t>
                </div>
            </div>
        </t>
    </template>
</odoo>
