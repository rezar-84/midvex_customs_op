<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Category for Customs Operations -->
    <record id="module_category_customs_operations" model="ir.module.category">
        <field name="name">Customs Operations</field>
        <field name="description">Management of international import shipments, document compliance, and customs clearance.</field>
        <field name="sequence">100</field>
    </record>

    <!-- Privilege for Customs Operations (Odoo 19 requirement) -->
    <record id="privilege_customs_operations" model="res.groups.privilege">
        <field name="name">Customs Operations Privilege</field>
        <field name="category_id" ref="module_category_customs_operations"/>
    </record>

    <!-- Security Groups -->
    <record id="group_customs_user" model="res.groups">
        <field name="name">Customs User</field>
        <field name="privilege_id" ref="privilege_customs_operations"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        <field name="comment">Can create and edit Customs Files, upload documents, and manage shipment details.</field>
    </record>

    <record id="group_customs_approver" model="res.groups">
        <field name="name">Customs Document Approver</field>
        <field name="privilege_id" ref="privilege_customs_operations"/>
        <field name="implied_ids" eval="[(4, ref('group_customs_user'))]"/>
        <field name="comment">Can review, approve, or reject customs document requirements.</field>
    </record>

    <record id="group_customs_manager" model="res.groups">
        <field name="name">Customs Manager</field>
        <field name="privilege_id" ref="privilege_customs_operations"/>
        <field name="implied_ids" eval="[(4, ref('group_customs_approver'))]"/>
        <field name="comment">Can override shipment readiness checks, close files, and view operational reports.</field>
    </record>

    <record id="group_customs_admin" model="res.groups">
        <field name="name">Customs Administrator</field>
        <field name="privilege_id" ref="privilege_customs_operations"/>
        <field name="implied_ids" eval="[(4, ref('group_customs_manager'))]"/>
        <field name="comment">Can configure workflow stages, document types, and manage system-wide customs master data.</field>
    </record>

    <!-- Multi-Company Record Rules (Global) -->
    <record id="customs_operation_comp_rule" model="ir.rule">
        <field name="name">Customs Operation Multi-Company Rule</field>
        <field name="model_id" ref="model_customs_operation"/>
        <field name="global" eval="True"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>

    <record id="customs_document_requirement_comp_rule" model="ir.rule">
        <field name="name">Customs Document Requirement Multi-Company Rule</field>
        <field name="model_id" ref="model_customs_document_requirement"/>
        <field name="global" eval="True"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>

    <record id="customs_stage_comp_rule" model="ir.rule">
        <field name="name">Customs Stage Multi-Company Rule</field>
        <field name="model_id" ref="model_customs_stage"/>
        <field name="global" eval="True"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
    </record>

    <record id="customs_document_type_comp_rule" model="ir.rule">
        <field name="name">Customs Document Type Multi-Company Rule</field>
        <field name="model_id" ref="model_customs_document_type"/>
        <field name="global" eval="True"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
    </record>
</odoo>
