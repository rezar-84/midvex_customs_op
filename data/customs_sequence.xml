<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Sequence for Customs Operations -->
        <record id="seq_customs_operation" model="ir.sequence">
            <field name="name">Customs File Reference</field>
            <field name="code">customs.operation</field>
            <field name="prefix">CUS/%(year)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
            <field name="use_date_range" eval="True"/>
        </record>
    </data>
</odoo>
