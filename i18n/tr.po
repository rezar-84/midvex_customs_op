#. module: midvex_customs_op
#: code:addons/midvex_customs_op/models/customs_operation.py:0
msgid "You cannot close Customs File %s because the following mandatory documents are incomplete:\n%s"
msgstr "Gümrük Dosyasını (%s) kapatamazsınız çünkü aşağıdaki zorunlu belgeler eksik:\n%s"

#. module: midvex_customs_op
#: code:addons/midvex_customs_op/models/customs_operation.py:0
msgid "You cannot close Customs File %s because there are open critical activities:\n%s"
msgstr "Gümrük Dosyasını (%s) kapatamazsınız çünkü açık kritik aktiviteler var:\n%s"

#. module: midvex_customs_op
#: code:addons/midvex_customs_op/models/customs_operation_line.py:0
msgid "The expiry date must be after the production date for product %s."
msgstr "Ürün (%s) için son kullanma tarihi üretim tarihinden sonra olmalıdır."

#. module: midvex_customs_op
#: code:addons/midvex_customs_op/models/customs_operation_line.py:0
msgid "Weights cannot be negative values."
msgstr "Ağırlıklar negatif değer olamaz."

#. module: midvex_customs_op
#: code:addons/midvex_customs_op/models/customs_operation_line.py:0
msgid "Net weight cannot exceed gross weight."
